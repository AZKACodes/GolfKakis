# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def patch_flutter_contacts_scene_crash
  plugin_file = File.join(
    __dir__,
    '.symlinks',
    'plugins',
    'flutter_contacts',
    'ios',
    'Classes',
    'SwiftFlutterContactsPlugin.swift',
  )
  return unless File.exist?(plugin_file)

  source = File.read(plugin_file)
  legacy_code = '        let rootViewController = UIApplication.shared.delegate!.window!!.rootViewController!'
  patched_code = <<~SWIFT.chomp
            let rootViewController = registrar.viewController
                ?? UIApplication.shared.connectedScenes
                    .compactMap { ($0 as? UIWindowScene)?.windows.first(where: { $0.isKeyWindow })?.rootViewController }
                    .first
                ?? UIApplication.shared.windows.first(where: { $0.isKeyWindow })?.rootViewController
                ?? UIViewController()
  SWIFT
  broken_code = <<~SWIFT.chomp
            let rootViewController = registrar.viewController()
                ?? UIApplication.shared.connectedScenes
                    .compactMap { ($0 as? UIWindowScene)?.keyWindow?.rootViewController }
                    .first
                ?? UIApplication.shared.windows.first(where: { $0.isKeyWindow })?.rootViewController
                ?? UIViewController()
  SWIFT
  previous_patched_code = <<~SWIFT.chomp
            let rootViewController = registrar.viewController
                ?? UIApplication.shared.connectedScenes
                    .compactMap { ($0 as? UIWindowScene)?.keyWindow?.rootViewController }
                    .first
                ?? UIApplication.shared.windows.first(where: { $0.isKeyWindow })?.rootViewController
                ?? UIViewController()
  SWIFT
  updated_source = source
    .sub(legacy_code, patched_code)
    .sub(broken_code, patched_code)
    .sub(previous_patched_code, patched_code)
  return if updated_source == source

  File.write(plugin_file, updated_source)
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  patch_flutter_contacts_scene_crash

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_PHOTOS_ADD_ONLY=1',
      ]
    end
  end
end
